# Copy to `.env` in this folder (gitignored). Restart Metro with `npx expo start --clear` after changes.
#
# Backend API base URL (no trailing slash).
EXPO_PUBLIC_API_URL=http://localhost:8000
#
# Physical device on same Wi‑Fi as your computer — use your machine's LAN IP, not localhost:
# EXPO_PUBLIC_API_URL=http://192.168.1.10:8000
#
# Android emulator (backend on host):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000
#
# iOS Simulator: http://localhost:8000 (default if you omit EXPO_PUBLIC_API_URL)
